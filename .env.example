# 复制本文件为 .env 后填写真实 API 配置
# 注意：.env 不要上传到 GitHub

# OpenAI-compatible API Key，例如 DeepSeek / OpenRouter / Kimi / 通义千问 / 智谱 / 硅基流动
AI_API_KEY=你的API密钥

# 当前选择的通道，网页会自动维护
AI_PROVIDER=deepseek

# API 地址，必须是 OpenAI-compatible 基础地址，不要带 /chat/completions
# DeepSeek 示例：https://api.deepseek.com
# OpenRouter 示例：https://openrouter.ai/api/v1
# Kimi 示例：https://api.moonshot.cn/v1
# 通义千问示例：https://dashscope.aliyuncs.com/compatible-mode/v1
# 智谱示例：https://open.bigmodel.cn/api/paas/v4
# 硅基流动示例：https://api.siliconflow.cn/v1
AI_BASE_URL=https://api.deepseek.com

# 模型名称
AI_MODEL=deepseek-chat

# 生成温度，越高表达越发散
AI_TEMPERATURE=0.6

# 请求超时时间，单位秒
AI_TIMEOUT=60

# 可选代理地址。如果出现 WinError 10013 且你的网络需要代理，可以填写
# AI_PROXY_URL=http://127.0.0.1:7890
AI_PROXY_URL=
